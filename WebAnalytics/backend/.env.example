PORT=3000
NODE_ENV=production

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_96_char_random_hex_secret_here

# Google OAuth2 — set these in your hosting platform's env vars dashboard
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Set to your production domain:
REDIRECT_URI=https://yourdomain.com/api/google/callback
FRONTEND_URL=https://yourdomain.com
